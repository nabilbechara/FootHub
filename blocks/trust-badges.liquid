{% stylesheet %}
  .fh-trust-badges {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 12px;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    width: 100%;
    box-sizing: border-box;
  }

  .fh-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
    text-align: center;
  }

  .fh-trust-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
  }

  .fh-trust-badge__text {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: 0.03em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .fh-trust-badge__sep {
    width: 1px;
    height: 32px;
    background: rgb(var(--color-foreground-rgb) / 0.15);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .fh-trust-badges {
      padding: 10px 8px;
    }

    .fh-trust-badge__text {
      font-size: 0.62rem;
    }

    .fh-trust-badge__icon svg {
      width: 18px;
      height: 18px;
    }
  }
{% endstylesheet %}

