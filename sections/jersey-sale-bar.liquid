{% comment %}
  Jersey sale bar
{% endcomment %}

<section class="jersey-sale-bar" style="--jersey-sale-bg: {{ section.settings.background }}; --jersey-sale-fg: {{ section.settings.text_color }};">
  <a class="jersey-sale-bar__link" href="{{ section.settings.link }}">
    <span class="jersey-sale-bar__eyebrow">{{ section.settings.eyebrow }}</span>
    <span class="jersey-sale-bar__message">{{ section.settings.message }}</span>
    <span class="jersey-sale-bar__cta">{{ section.settings.cta }}</span>
  </a>
</section>

<style>
  .jersey-sale-bar {
    background: var(--jersey-sale-bg);
    color: var(--jersey-sale-fg);
  }

  .jersey-sale-bar__link {
    min-height: 38px;
    padding: 8px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: inherit;
    text-decoration: none;
    text-align: center;
    font-family: "Montserrat", "Helvetica Neue", Arial, sans-serif;
  }

  .jersey-sale-bar__eyebrow {
    padding: 4px 8px;
    background: #d40000;
    color: #fff;
    font-size: 0.72rem;
    line-height: 1;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .jersey-sale-bar__message {
    font-size: 0.92rem;
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .jersey-sale-bar__cta {
    font-size: 0.76rem;
    line-height: 1;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .jersey-sale-bar__link {
      min-height: 44px;
      padding: 8px 12px;
      gap: 8px;
      flex-wrap: wrap;
    }

    .jersey-sale-bar__message {
      width: 100%;
      order: 3;
      font-size: 0.78rem;
    }
  }
</style>

{% schema %}
{
  "name": "Jersey Sale Bar",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited offer"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Football jerseys now $19.99"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "CTA",
      "default": "Shop jerseys"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#050505"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Jersey Sale Bar"
    }
  ]
}
{% endschema %}
