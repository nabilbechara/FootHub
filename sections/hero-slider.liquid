<section class="hero-slider">
  <div class="hero-slider-wrapper">
    {% for block in section.blocks %}
      <div
        class="hero-slide {% if forloop.first %}active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="hero-slide-link">
        {% endif %}

          {% if block.settings.desktop_image != blank %}
            <img
              class="hero-image hero-image-desktop"
              src="{{ block.settings.desktop_image | image_url: width: 2600 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {% endif %}

          {% if block.settings.mobile_image != blank %}
            <img
              class="hero-image hero-image-mobile"
              src="{{ block.settings.mobile_image | image_url: width: 1600 }}"
              alt="{{ block.settings.mobile_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {% endif %}

          {% if block.settings.logo != blank or block.settings.kicker != blank or block.settings.heading != blank or block.settings.subheading != blank or block.settings.button_label != blank %}
            <div class="hero-slide__overlay">
              <div class="hero-slide__content">
                {% if block.settings.logo != blank %}
                  <img
                    class="hero-slide__logo"
                    src="{{ block.settings.logo | image_url: width: 360 }}"
                    alt="{{ shop.name | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  >
                {% endif %}

                {% if block.settings.kicker != blank %}
                  <p class="hero-slide__kicker">{{ block.settings.kicker }}</p>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <h2 class="hero-slide__heading">{{ block.settings.heading }}</h2>
                {% endif %}

                {% if block.settings.subheading != blank %}
                  <p class="hero-slide__subheading">{{ block.settings.subheading }}</p>
                {% endif %}

                {% if block.settings.button_label != blank %}
                  <span class="hero-slide__button">{{ block.settings.button_label }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="hero-dots">
      {% for block in section.blocks %}
        <span
          class="hero-dot {% if forloop.first %}active{% endif %}"
          data-index="{{ forloop.index0 }}"
        ></span>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
/* ================================
   HERO SLIDER – PRODUCTION
   ================================ */

.hero-slider {
  position: relative;
  width: 100%;
  background: #000;
  overflow: hidden;
}

.hero-slider-wrapper {
  width: 100%;
  display: grid;
}

/* Slides */
.hero-slide {
  grid-area: 1 / 1;
  width: 100%;
  position: relative;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  z-index: 0;
  transition: opacity 0.55s ease, visibility 0s linear 0.55s;
}

.hero-slide.active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  z-index: 1;
  transition: opacity 0.55s ease, visibility 0s linear 0s;
}

/* Link wrapper */
.hero-slide-link {
  display: block;
  width: 100%;
  position: relative;
  color: inherit;
  text-decoration: none;
}

/* Images */
.hero-image {
  display: block;
  width: 100%;
}

.hero-slide__overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: linear-gradient(180deg, rgba(0,0,0,0.06), rgba(0,0,0,0.14) 50%, rgba(0,0,0,0.48));
  pointer-events: none;
}

.hero-slide__content {
  width: min(980px, calc(100% - 48px));
  margin: 0 auto;
  padding: 0 0 clamp(58px, 8vw, 106px);
  color: #fff;
  text-align: center;
}

.hero-slide__logo {
  position: absolute;
  top: clamp(32px, 6vw, 74px);
  left: 50%;
  width: clamp(82px, 11vw, 148px);
  height: auto;
  transform: translateX(-50%);
  filter: invert(1) drop-shadow(0 4px 14px rgba(0,0,0,0.28));
}

.hero-slide__kicker {
  margin: 0 0 12px;
  font-size: 0.78rem;
  line-height: 1.2;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.hero-slide__heading {
  max-width: 880px;
  margin: 0 auto;
  font-size: clamp(2.8rem, 5.7vw, 6.1rem);
  line-height: 1.02;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: uppercase;
  text-shadow: 0 6px 0 rgba(0,0,0,0.45);
}

.hero-slide__subheading {
  max-width: 520px;
  margin: 18px auto 0;
  font-size: clamp(1rem, 1.5vw, 1.2rem);
  line-height: 1.5;
  color: rgba(255,255,255,0.9);
}

.hero-slide__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: min(460px, 82vw);
  min-height: clamp(56px, 6vw, 82px);
  margin-top: clamp(18px, 2.6vw, 28px);
  padding: 0 42px;
  border-radius: 999px;
  background: #ffffff;
  color: #07111a;
  font-family: "Montserrat", "Helvetica Neue", Arial, sans-serif;
  font-size: clamp(1.25rem, 2.8vw, 2.6rem);
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.105em;
  box-shadow: 0 10px 24px rgba(0,0,0,0.24);
  transition: transform 0.2s ease, background 0.2s ease;
}

.hero-slide-link:hover .hero-slide__button {
  transform: translateY(-2px);
  background: #f1f5f9;
}

/* ================================
   MOBILE (natural height)
   ================================ */
.hero-image-mobile {
  display: block;
  height: auto;
}

.hero-image-desktop {
  display: none;
}

@media (max-width: 768px) {
  .hero-slide__overlay {
    align-items: flex-end;
    background: linear-gradient(180deg, rgba(0,0,0,0.04), rgba(0,0,0,0.16) 48%, rgba(0,0,0,0.58));
  }

  .hero-slide__content {
    width: calc(100% - 34px);
    padding-bottom: 56px;
  }

  .hero-slide__logo {
    top: 30px;
    width: clamp(84px, 25vw, 124px);
  }

  .hero-slide__heading {
    max-width: 720px;
    font-size: clamp(2.8rem, 8.4vw, 5.2rem);
    line-height: 1.12;
    text-shadow: 0 5px 0 rgba(0,0,0,0.5);
  }

  .hero-slide__subheading {
    max-width: 310px;
    margin-top: 12px;
    font-size: 0.98rem;
  }

  .hero-slide__button {
    min-width: min(500px, 76vw);
    min-height: 66px;
    margin-top: 18px;
    padding: 0 26px;
    font-size: clamp(1.5rem, 6.3vw, 2.3rem);
  }
}

/* ================================
   DESKTOP (landscape hero)
   ================================ */
@media (min-width: 769px) {
  .hero-image-desktop {
    display: block;
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
  }

  .hero-image-mobile {
    display: none;
  }

  .hero-slide__content {
    padding-bottom: clamp(34px, 5vw, 72px);
  }

  .hero-slide__logo {
    top: clamp(22px, 3.4vw, 42px);
    width: clamp(70px, 7.2vw, 104px);
  }

  .hero-slide__heading {
    max-width: 780px;
    font-size: clamp(2.2rem, 4.4vw, 4.6rem);
    line-height: 1.04;
    text-shadow: 0 5px 0 rgba(0,0,0,0.45);
  }

  .hero-slide__button {
    min-width: min(360px, 42vw);
    min-height: clamp(50px, 4.8vw, 68px);
    font-size: clamp(1.05rem, 2vw, 1.8rem);
  }
}

@media (max-width: 420px) {
  .hero-slide__content {
    padding-bottom: 44px;
  }

  .hero-slide__heading {
    font-size: clamp(2.25rem, 9.7vw, 3.7rem);
  }

  .hero-slide__button {
    min-height: 58px;
    font-size: clamp(1.28rem, 6vw, 1.82rem);
  }
}

/* ================================
   DOTS
   ================================ */
.hero-dots {
  position: absolute;
  bottom: 12px;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 6px;
  z-index: 5;
}

.hero-dot {
  width: 16px;
  height: 2px;
  border-radius: 999px;
  background: rgba(255,255,255,0.38);
  cursor: pointer;
  transition: background 0.3s ease;
}

.hero-dot.active {
  background: #ffffff;
}

@media (max-width: 768px) {
  .hero-dots {
    bottom: 8px;
  }

  .hero-dot {
    width: 20px;
    height: 2px;
    opacity: 0.78;
  }
}
</style>

<script>
(function () {
  function initHeroSlider() {
    const slider = document.querySelector(".hero-slider");
    if (!slider) return;

    const slides = slider.querySelectorAll(".hero-slide");
    const dots = slider.querySelectorAll(".hero-dot");
    let index = 0;
    const intervalTime = 5000;

    function showSlide(i) {
      slides.forEach(s => s.classList.remove("active"));
      slides[i].classList.add("active");

      if (dots.length) {
        dots.forEach(d => d.classList.remove("active"));
        dots[i].classList.add("active");
      }

      index = i;
    }

    dots.forEach(dot => {
      dot.addEventListener("click", () => {
        showSlide(parseInt(dot.dataset.index, 10));
      });
    });

    if (slides.length > 1) {
      setInterval(() => {
        showSlide((index + 1) % slides.length);
      }, intervalTime);
    }
  }

  document.addEventListener("DOMContentLoaded", initHeroSlider);
  document.addEventListener("shopify:section:load", initHeroSlider);
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 10,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image (landscape – 2400 × 900)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (portrait – 1080 × 1600)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Overlay logo (optional)"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "FootHub"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Headline",
          "default": "Built for the Pitch"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Curated football boots, kits, and essentials for players who show up ready."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider (Desktop + Mobile)"
    }
  ]
}
{% endschema %}
