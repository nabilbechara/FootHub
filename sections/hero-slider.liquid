<section class="hero-slider">
  <div class="hero-slider-wrapper">
    {% for block in section.blocks %}
      <div
        class="hero-slide {% if forloop.first %}active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="hero-slide-link">
        {% endif %}

          {% if block.settings.desktop_image != blank %}
            <img
              class="hero-image hero-image-desktop"
              src="{{ block.settings.desktop_image | image_url: width: 2600 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {% endif %}

          {% if block.settings.mobile_image != blank %}
            <img
              class="hero-image hero-image-mobile"
              src="{{ block.settings.mobile_image | image_url: width: 1600 }}"
              alt="{{ block.settings.mobile_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="hero-dots">
      {% for block in section.blocks %}
        <span
          class="hero-dot {% if forloop.first %}active{% endif %}"
          data-index="{{ forloop.index0 }}"
        ></span>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
/* ================================
   HERO SLIDER – PRODUCTION
   ================================ */

.hero-slider {
  position: relative;
  width: 100%;
  background: #000;
  overflow: hidden;
}

.hero-slider-wrapper {
  width: 100%;
}

/* Slides */
.hero-slide {
  display: none;
  width: 100%;
}

.hero-slide.active {
  display: block;
}

/* Link wrapper */
.hero-slide-link {
  display: block;
  width: 100%;
}

/* Images */
.hero-image {
  display: block;
  width: 100%;
}

/* ================================
   MOBILE (natural height)
   ================================ */
.hero-image-mobile {
  display: block;
  height: auto;
}

.hero-image-desktop {
  display: none;
}

/* ================================
   DESKTOP (landscape hero)
   ================================ */
@media (min-width: 769px) {
  .hero-image-desktop {
    display: block;
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
  }

  .hero-image-mobile {
    display: none;
  }
}

/* ================================
   DOTS
   ================================ */
.hero-dots {
  position: absolute;
  bottom: 16px;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 8px;
  z-index: 5;
}

.hero-dot {
  width: 18px;
  height: 3px;
  background: rgba(255,255,255,0.4);
  cursor: pointer;
  transition: background 0.3s ease;
}

.hero-dot.active {
  background: #ffffff;
}
</style>

<script>
(function () {
  function initHeroSlider() {
    const slider = document.querySelector(".hero-slider");
    if (!slider) return;

    const slides = slider.querySelectorAll(".hero-slide");
    const dots = slider.querySelectorAll(".hero-dot");
    let index = 0;
    const intervalTime = 5000;

    function showSlide(i) {
      slides.forEach(s => s.classList.remove("active"));
      slides[i].classList.add("active");

      if (dots.length) {
        dots.forEach(d => d.classList.remove("active"));
        dots[i].classList.add("active");
      }

      index = i;
    }

    dots.forEach(dot => {
      dot.addEventListener("click", () => {
        showSlide(parseInt(dot.dataset.index, 10));
      });
    });

    if (slides.length > 1) {
      setInterval(() => {
        showSlide((index + 1) % slides.length);
      }, intervalTime);
    }
  }

  document.addEventListener("DOMContentLoaded", initHeroSlider);
  document.addEventListener("shopify:section:load", initHeroSlider);
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 10,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image (landscape – 2400 × 900)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (portrait – 1080 × 1600)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider (Desktop + Mobile)"
    }
  ]
}
{% endschema %}
