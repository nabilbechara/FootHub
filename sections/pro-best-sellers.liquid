{% comment %}
  Pro Best Sellers - static product grid
{% endcomment %}

<section class="pro-bestsellers">
  <div class="pro-bestsellers__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-bestsellers__header">
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.settings.collection != blank %}
      <div class="pro-bestsellers__wrapper">
        <div class="pro-bestsellers__grid">
          {% for product in section.settings.collection.products limit: section.settings.products_limit %}
            <div class="pro-bestsellers__card">

              <div class="pro-bestsellers__image">
                {% if product.compare_at_price > product.price %}
                  <span class="pro-bestsellers__badge">Sale</span>
                {% endif %}
                {% if product.featured_image %}
                  <a href="{{ product.url }}" class="pro-bestsellers__image-link" aria-label="{{ product.title | escape }}">
                    <img
                      src="{{ product.featured_image | image_url: width: 900 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                    >
                  </a>
                {% endif %}

                {% if product.available %}
                  <form method="post" action="/cart/add" class="pro-bestsellers__quick-add">
                    <p class="pro-bestsellers__quick-title">{{ product.title }}</p>
                    <div class="pro-bestsellers__variant-row">
                      <span class="pro-bestsellers__variant-label">Size:</span>
                      {% assign rendered_variants = 0 %}
                      {% for variant in product.variants %}
                        {% if variant.available and rendered_variants < 7 %}
                          <label class="pro-bestsellers__variant">
                            <input
                              type="radio"
                              name="id"
                              value="{{ variant.id }}"
                              {% if rendered_variants == 0 %}checked{% endif %}
                            >
                            <span>{{ variant.title | replace: 'Default Title', 'One Size' }}</span>
                          </label>
                          {% assign rendered_variants = rendered_variants | plus: 1 %}
                        {% endif %}
                      {% endfor %}
                    </div>
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="pro-bestsellers__quick-button">Add to cart</button>
                  </form>
                {% endif %}
              </div>

              <div class="pro-bestsellers__info">
                <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
                <p class="pro-bestsellers__price">
                  <span>{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <s>{{ product.compare_at_price | money }}</s>
                  {% endif %}
                </p>
              </div>

            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.view_more_label != blank and section.settings.view_more_link != blank %}
        <div class="pro-bestsellers__cta">
          <a href="{{ section.settings.view_more_link }}" class="pro-bestsellers__view-more">
            {{ section.settings.view_more_label }}
          </a>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% if section.settings.collection != blank %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ section.settings.heading | json }},
  "itemListElement": [
    {% for product in section.settings.collection.products limit: section.settings.products_limit %}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "item": {
        "@type": "Product",
        "name": {{ product.title | json }},
        "url": {{ request.origin | append: product.url | json }},
        {% if product.featured_image %}
        "image": {{ product.featured_image | image_url: width: 900 | prepend: "https:" | json }},
        {% endif %}
        "offers": {
          "@type": "Offer",
          "price": "{{ product.price | money_without_currency | strip_html }}",
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
        }
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<style>
  .pro-bestsellers {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: #f8f8f6;
  }

  .pro-bestsellers__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .pro-bestsellers__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .pro-bestsellers__header h2 {
    margin: 0 0 10px;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #161616;
  }

  .pro-bestsellers__header p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #6f6a64;
  }

  .pro-bestsellers__wrapper {
    position: relative;
  }

  .pro-bestsellers__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    column-gap: 54px;
    row-gap: 64px;
    align-items: start;
  }

  .pro-bestsellers__card {
    color: #161616;
    transition: transform 0.25s ease;
  }

  .pro-bestsellers__card:hover {
    transform: translateY(-4px);
  }

  .pro-bestsellers__image {
    position: relative;
    background: #f7f7f7;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .pro-bestsellers__image-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 8%;
  }

  .pro-bestsellers__image img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
    transform: scale(1.08);
    transform-origin: center;
  }

  .pro-bestsellers__badge {
    position: absolute;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 26px;
    padding: 0 10px;
    background: #d40000;
    color: #ffffff;
    font-size: 0.7rem;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .pro-bestsellers__badge {
    top: 8px;
    left: 0;
  }

  .pro-bestsellers__quick-add {
    position: absolute;
    left: 50%;
    bottom: 12px;
    z-index: 4;
    width: min(92%, 330px);
    padding: 12px;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 14px 34px rgba(0,0,0,0.16);
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 10px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0.2s;
  }

  .pro-bestsellers__card:hover .pro-bestsellers__quick-add,
  .pro-bestsellers__quick-add:focus-within {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0s;
  }

  .pro-bestsellers__quick-title {
    display: inline-block;
    margin: 0 0 10px;
    padding: 5px 8px;
    background: #1f1f1f;
    color: #ffffff;
    font-size: 0.72rem;
    line-height: 1.1;
  }

  .pro-bestsellers__variant-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .pro-bestsellers__variant-label {
    margin-right: 4px;
    font-size: 0.78rem;
  }

  .pro-bestsellers__variant input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .pro-bestsellers__variant span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 34px;
    border: 1px solid #d8d8d8;
    background: #ffffff;
    color: #111111;
    font-size: 0.78rem;
    cursor: pointer;
  }

  .pro-bestsellers__variant input:checked + span {
    background: #000000;
    border-color: #000000;
    color: #ffffff;
  }

  .pro-bestsellers__quick-button {
    width: 100%;
    height: 42px;
    border: 0;
    background: #000000;
    color: #ffffff;
    font-size: 0.92rem;
    cursor: pointer;
  }

  .pro-bestsellers__info {
    padding-top: 14px;
    text-align: center;
  }

  .pro-bestsellers__info h3 {
    margin: 0 0 8px;
    font-size: 1.05rem;
    line-height: 1.3;
    font-weight: 500;
    color: #171717;
    min-height: 2.8em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pro-bestsellers__info h3 a {
    color: inherit;
    text-decoration: none;
  }

  .pro-bestsellers__price {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #111111;
  }

  .pro-bestsellers__price s {
    margin-left: 6px;
    color: #111111;
    font-weight: 400;
  }

  .pro-bestsellers__nav {
    display: none;
  }

  .pro-bestsellers__cta {
    text-align: center;
    margin-top: 46px;
  }

  .pro-bestsellers__view-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 30px;
    min-height: 50px;
    border: 1px solid #161616;
    border-radius: 999px;
    background: transparent;
    color: #161616;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: all 0.25s ease;
  }

  .pro-bestsellers__view-more:hover {
    background: #161616;
    color: #ffffff;
    transform: translateY(-2px);
  }

  @media (max-width: 990px) {
    .pro-bestsellers__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: 18px;
      row-gap: 36px;
    }
  }

  @media (max-width: 768px) {
    .pro-bestsellers {
      padding: calc({{ section.settings.padding_y }}px * 0.8) 16px;
    }

    .pro-bestsellers__header {
      margin-bottom: 30px;
    }

    .pro-bestsellers__header h2 {
      font-size: clamp(1.9rem, 8vw, 2.5rem);
    }

    .pro-bestsellers__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 18px;
      row-gap: 34px;
    }

    .pro-bestsellers__card {
      min-width: 0;
    }

    .pro-bestsellers__image-link {
      padding: 9%;
    }

    .pro-bestsellers__image img {
      transform: scale(1.12);
    }

    .pro-bestsellers__quick-add {
      display: none;
    }

    .pro-bestsellers__cta {
      margin-top: 34px;
    }

    .pro-bestsellers__view-more {
      min-width: 148px;
      border-radius: 0;
      background: #000000;
      color: #ffffff;
      border-color: #000000;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Best Sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Top picks trusted by players." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_limit", "label": "Number of products", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "url", "id": "view_more_link", "label": "View more link" },
    { "type": "text", "id": "view_more_label", "label": "View more text", "default": "View all products" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 800, "max": 1600, "step": 40, "unit": "px", "default": 1480 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_x", "label": "Horizontal padding", "min": 12, "max": 64, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "radius", "label": "Image corner radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 12 }
  ],
  "presets": [{ "name": "Pro Best Sellers" }]
}
{% endschema %}
