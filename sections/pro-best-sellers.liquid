{% comment %}
  Pro Best Sellers – premium clean version
  - No sizes
  - Cleaner product image framing like collection page
  - Premium typography
  - View more button kept
{% endcomment %}

<section class="pro-bestsellers">
  <div class="pro-bestsellers__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-bestsellers__header">
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.settings.collection != blank %}
      <div class="pro-bestsellers__wrapper">

        <button class="pro-bestsellers__nav prev" aria-label="Previous products" type="button">
          ‹
        </button>

        <div class="pro-bestsellers__grid" id="BestSellersSlider">
          {% for product in section.settings.collection.products limit: section.settings.products_limit %}
            <a href="{{ product.url }}" class="pro-bestsellers__card">

              <div class="pro-bestsellers__image">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 900 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {% endif %}
              </div>

              <div class="pro-bestsellers__info">
                <h3>{{ product.title }}</h3>
                <p class="pro-bestsellers__price">{{ product.price | money }}</p>
              </div>

            </a>
          {% endfor %}
        </div>

        <button class="pro-bestsellers__nav next" aria-label="Next products" type="button">
          ›
        </button>

      </div>

      {% if section.settings.view_more_label != blank and section.settings.view_more_link != blank %}
        <div class="pro-bestsellers__cta">
          <a href="{{ section.settings.view_more_link }}" class="pro-bestsellers__view-more">
            {{ section.settings.view_more_label }}
          </a>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

<style>
  .pro-bestsellers {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: #f8f8f6;
  }

  .pro-bestsellers__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .pro-bestsellers__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .pro-bestsellers__header h2 {
    margin: 0 0 10px;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #161616;
  }

  .pro-bestsellers__header p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #6f6a64;
  }

  .pro-bestsellers__wrapper {
    position: relative;
  }

  .pro-bestsellers__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 32px;
  }

  .pro-bestsellers__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: #161616;
    transition: transform 0.25s ease;
  }

  .pro-bestsellers__card:hover {
    transform: translateY(-4px);
  }

  .pro-bestsellers__image {
    background: #f3f3f3;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .pro-bestsellers__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .pro-bestsellers__info {
    padding-top: 18px;
  }

  .pro-bestsellers__info h3 {
    margin: 0 0 8px;
    font-size: 1.02rem;
    line-height: 1.4;
    font-weight: 500;
    color: #171717;
    min-height: 2.8em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pro-bestsellers__price {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #111111;
  }

  .pro-bestsellers__nav {
    display: none;
  }

  .pro-bestsellers__cta {
    text-align: center;
    margin-top: 46px;
  }

  .pro-bestsellers__view-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 30px;
    min-height: 50px;
    border: 1px solid #161616;
    border-radius: 999px;
    background: transparent;
    color: #161616;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: all 0.25s ease;
  }

  .pro-bestsellers__view-more:hover {
    background: #161616;
    color: #ffffff;
    transform: translateY(-2px);
  }

  @media (max-width: 990px) {
    .pro-bestsellers__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .pro-bestsellers {
      padding: calc({{ section.settings.padding_y }}px * 0.8) 16px;
    }

    .pro-bestsellers__header {
      margin-bottom: 30px;
    }

    .pro-bestsellers__header h2 {
      font-size: clamp(1.9rem, 8vw, 2.5rem);
    }

    .pro-bestsellers__grid {
      display: flex;
      overflow-x: auto;
      gap: 16px;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;
    }

    .pro-bestsellers__grid::-webkit-scrollbar {
      display: none;
    }

    .pro-bestsellers__card {
      min-width: 82%;
      scroll-snap-align: start;
    }

    .pro-bestsellers__nav {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 34%;
      width: 40px;
      height: 40px;
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
      font-size: 24px;
      line-height: 1;
      cursor: pointer;
      z-index: 2;
    }

    .pro-bestsellers__nav.prev {
      left: -6px;
    }

    .pro-bestsellers__nav.next {
      right: -6px;
    }

    .pro-bestsellers__cta {
      margin-top: 34px;
    }

    .pro-bestsellers__view-more {
      width: 100%;
      max-width: 280px;
    }
  }
</style>

<script>
  (function () {
    const slider = document.getElementById('BestSellersSlider');
    if (!slider) return;

    const prev = slider.parentElement.querySelector('.prev');
    const next = slider.parentElement.querySelector('.next');

    if (prev) {
      prev.addEventListener('click', function () {
        slider.scrollBy({ left: -slider.clientWidth * 0.9, behavior: 'smooth' });
      });
    }

    if (next) {
      next.addEventListener('click', function () {
        slider.scrollBy({ left: slider.clientWidth * 0.9, behavior: 'smooth' });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Pro Best Sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Top picks trusted by players." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_limit", "label": "Number of products", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "url", "id": "view_more_link", "label": "View more link" },
    { "type": "text", "id": "view_more_label", "label": "View more text", "default": "View all products" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 800, "max": 1400, "step": 40, "unit": "px", "default": 1200 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_x", "label": "Horizontal padding", "min": 12, "max": 64, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "radius", "label": "Image corner radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 12 }
  ],
  "presets": [{ "name": "Pro Best Sellers" }]
}
{% endschema %}