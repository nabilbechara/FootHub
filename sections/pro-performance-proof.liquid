{% comment %}
  Pro Performance Proof – Premium Trust Section
{% endcomment %}

<section
  class="pro-proof"
  style="
    --pad-y: {{ section.settings.padding_y }}px;
    --pad-x: {{ section.settings.padding_x }}px;
    --max: {{ section.settings.max_width }}px;
    --bg: {{ section.settings.background }};
  "
>
  <div class="pro-proof__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-proof__header">
        <span class="pro-proof__kicker">{{ section.settings.kicker }}</span>
        <h2 class="pro-proof__heading">{{ section.settings.heading }}</h2>
      </header>
    {% endif %}

    <div class="pro-proof__grid">
      {% for block in section.blocks %}
        <div class="pro-proof__item" {{ block.shopify_attributes }}>
          <p class="pro-proof__text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .pro-proof {
    padding: var(--pad-y) var(--pad-x);
    background: var(--bg);
  }

  .pro-proof__inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .pro-proof__header {
    max-width: 720px;
    margin-bottom: 48px;
  }

  .pro-proof__kicker {
    display: inline-block;
    margin-bottom: 14px;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .pro-proof__heading {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.3rem);
    line-height: 1.15;
    color: #0f0f0f;
  }

  /* GRID */
  .pro-proof__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 40px);
  }

  .pro-proof__item {
    position: relative;
    padding-left: 18px;
  }

  .pro-proof__item::before {
    content: "•";
    position: absolute;
    left: 0;
    top: 0;
    color: #111;
    font-size: 1.1rem;
    line-height: 1;
  }

  .pro-proof__text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: #374151;
    max-width: 32ch;
  }

  /* MOBILE */
  @media (max-width: 900px) {
    .pro-proof__grid {
      grid-template-columns: 1fr;
    }

    .pro-proof__item {
      padding-left: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Performance Proof",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small kicker text",
      "default": "PROVEN ON MATCH DAY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted where performance matters."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Engineered for grip, speed, and control at match intensity."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Pro Performance Proof",
      "blocks": [
        {
          "type": "proof",
          "settings": {
            "text": "Engineered for grip, speed, and control at match intensity."
          }
        },
        {
          "type": "proof",
          "settings": {
            "text": "Trusted by competitive players worldwide, from training to match day."
          }
        },
        {
          "type": "proof",
          "settings": {
            "text": "Fast shipping, easy exchanges, and secure checkout."
          }
        }
      ]
    }
  ]
}
{% endschema %}
