{% comment %}
  Pro Match-Day Setup – Curated Performance System
{% endcomment %}

<section class="pro-setup">
  <div class="pro-setup__inner">

    <!-- LEFT: EDITORIAL -->
    <div class="pro-setup__content">
      {% if section.settings.kicker != blank %}
        <span class="pro-setup__kicker">{{ section.settings.kicker }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="pro-setup__text">
          {{ section.settings.text }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="pro-setup__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <!-- RIGHT: PRODUCTS -->
    <div class="pro-setup__products">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        {% if product %}
          <a href="{{ product.url }}" class="pro-setup__product" {{ block.shopify_attributes }}>
            <div class="pro-setup__image">
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
              >
            </div>
            <div class="pro-setup__meta">
              <span class="pro-setup__title">{{ product.title }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .pro-setup {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: #ffffff;
  }

  .pro-setup__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    align-items: center;
  }

  /* CONTENT */
  .pro-setup__kicker {
    display: inline-block;
    margin-bottom: 12px;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .pro-setup h2 {
    margin: 0 0 16px;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    line-height: 1.15;
    color: #111;
  }

  .pro-setup__text {
    max-width: 44ch;
    font-size: 1rem;
    line-height: 1.6;
    color: #374151;
  }

  .pro-setup__button {
    display: inline-block;
    margin-top: 28px;
    padding: 14px 28px;
    border-radius: 999px;
    border: 1px solid #111;
    text-decoration: none;
    color: #111;
    font-weight: 500;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .pro-setup__button:hover {
    background: #111;
    color: #fff;
  }

  /* PRODUCTS */
  .pro-setup__products {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .pro-setup__product {
    text-decoration: none;
    color: inherit;
  }

  .pro-setup__image {
    background: #f5f5f5;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .pro-setup__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.25s ease;
  }

  .pro-setup__product:hover img {
    transform: scale(1.04);
  }

  .pro-setup__meta {
    margin-top: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #111;
  }

  /* MOBILE */
  @media (max-width: 900px) {
    .pro-setup__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .pro-setup__products {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Match-Day Setup",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "MATCH-DAY SETUP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need. Nothing you don’t."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We’ve curated a professional match-day setup trusted by competitive players. No guesswork. No compromises. Just gear that performs together when it matters."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the match-day setup"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 900,
      "max": 1380,
      "step": 40,
      "unit": "px",
      "default": 1180
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 60,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Image radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Pro Match-Day Setup",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
