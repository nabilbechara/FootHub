{% comment %}
  Pro Brand Story – Premium Editorial / Performance
{% endcomment %}

<section
  class="pro-story"
  style="
    --story-max: {{ section.settings.max_width }}px;
    --pad-y: {{ section.settings.padding_y }}px;
    --pad-x: {{ section.settings.padding_x }}px;
    --radius: {{ section.settings.radius }}px;
    --bg: {{ section.settings.background }};
  "
>
  <div class="pro-story__inner">

    <div class="pro-story__grid">

      <!-- TEXT -->
      <div class="pro-story__content">
        {% if section.settings.kicker != blank %}
          <span class="pro-story__kicker">{{ section.settings.kicker }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="pro-story__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="pro-story__text">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="pro-story__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <!-- IMAGE -->
      <div class="pro-story__image">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
          >
        {% else %}
          <div class="pro-story__image-placeholder">
            Add an image
          </div>
        {% endif %}
      </div>

    </div>

  </div>
</section>

<style>
  .pro-story {
    padding: var(--pad-y) var(--pad-x);
    background: var(--bg);
  }

  .pro-story__inner {
    max-width: var(--story-max);
    margin: 0 auto;
  }

  .pro-story__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }

  /* TEXT */
  .pro-story__kicker {
    display: inline-block;
    margin-bottom: 14px;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .pro-story__heading {
    margin: 0 0 18px;
    font-size: clamp(2rem, 3.5vw, 2.6rem);
    line-height: 1.15;
    color: #0f0f0f;
    max-width: 18ch;
  }

  .pro-story__text {
    font-size: 1rem;
    line-height: 1.65;
    color: #374151;
    max-width: 46ch;
  }

  .pro-story__text p {
    margin: 0 0 12px;
  }

  .pro-story__text p:last-child {
    margin-bottom: 0;
  }

  .pro-story__button {
    display: inline-flex;
    align-items: center;
    margin-top: 26px;
    padding: 11px 22px;
    border-radius: 999px;
    border: 1px solid #111;
    text-decoration: none;
    color: #111;
    font-weight: 500;
    font-size: 0.95rem;
    transition: transform 0.12s ease, background 0.12s ease;
  }

  .pro-story__button:hover {
    transform: translateY(-1px);
    background: #111;
    color: #fff;
  }

  /* IMAGE */
  .pro-story__image {
    border-radius: var(--radius);
    overflow: hidden;
    background: #f3f4f6;
  }

  .pro-story__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .pro-story__image-placeholder {
    height: 360px;
    display: grid;
    place-items: center;
    color: #9ca3af;
    font-size: 0.85rem;
  }

  /* MOBILE */
  @media (max-width: 900px) {
    .pro-story__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .pro-story__heading {
      max-width: 100%;
    }

    .pro-story__text {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small kicker text",
      "default": "BUILT FOR MATCH DAY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Performance-first football gear."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Story text",
      "default": "<p>We curate professional-grade football shoes, jerseys, and equipment — chosen for players who demand performance when it matters.</p><p>No gimmicks. Just gear built to perform.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Pro Brand Story"
    }
  ]
}
{% endschema %}
