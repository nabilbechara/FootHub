{% comment %}
  Pro Category Grid - Desktop Premium / Mobile Visual Stack
{% endcomment %}

<section class="pro-categories">
  <div class="pro-categories__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-categories__header">
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="pro-categories__grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="pro-categories__card"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
            >
          {% endif %}

          <div
            class="pro-categories__overlay"
            style="opacity: {{ block.settings.overlay | divided_by: 100.0 }};"
          ></div>

          <div class="pro-categories__content">
            <h3>{{ block.settings.title }}</h3>
            {% if block.settings.subtitle != blank %}
              <p>{{ block.settings.subtitle }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  /* Base */
  .pro-categories {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: #ffffff;
  }

  .pro-categories__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .pro-categories__header {
    text-align: center;
    margin-bottom: 30px;
  }

  .pro-categories__header h2 {
    margin: 0 0 8px;
    font-family: "Montserrat", "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(1.55rem, 3vw, 2.3rem);
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #111;
  }

  .pro-categories__header p {
    margin: 0;
    font-size: 1rem;
    color: #6b7280;
  }

  /* Desktop Grid */
  .pro-categories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pro-categories__card {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.radius }}px;
    text-decoration: none;
    color: #fff;
    min-height: 380px;
    background: #000;
  }

  .pro-categories__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .pro-categories__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    z-index: 1;
  }

  .pro-categories__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pro-categories__content h3 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .pro-categories__content p {
    margin: 6px 0 0;
    font-size: 0.95rem;
    opacity: 0.9;
  }

  .pro-categories__card:hover img {
    transform: scale(1.06);
  }

  /* =========================
     MOBILE - VISUAL STACK
     ========================= */
  @media (max-width: 900px) {
    .pro-categories__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .pro-categories {
      padding-top: 40px;
    }

    .pro-categories__header {
      margin-bottom: 24px;
    }

    .pro-categories__header h2 {
      font-size: clamp(1.45rem, 7vw, 2rem);
    }

    .pro-categories__card {
      min-height: 210px;
      display: flex;
      align-items: flex-end;
    }

    .pro-categories__card img {
      position: absolute;
      inset: 0;
    }

    .pro-categories__content {
      padding: 22px;
      justify-content: flex-end;
    }

    .pro-categories__content h3 {
      font-size: 1.25rem;
      line-height: 1.2;
    }

    .pro-categories__content p {
      font-size: 0.92rem;
      max-width: 90%;
    }
  }

  @media (max-width: 420px) {
    .pro-categories__card {
      min-height: 200px;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional football gear for training and match day."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Football Shoes"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Speed, control & traction"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "overlay",
          "label": "Image overlay",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 45
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Pro Category Grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
