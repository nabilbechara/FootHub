{% if section.blocks.size > 0 %}
<section class="editorial-faq color-{{ section.settings.color_scheme }}">
  <div class="page-width editorial-faq__grid">

    <!-- LEFT COLUMN -->
    <div class="editorial-faq__left">
      <h2 class="editorial-faq__heading">
        {{ section.settings.heading }}
      </h2>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="editorial-faq__right">
      {% for block in section.blocks %}
        <details class="editorial-faq__item" {{ block.shopify_attributes }}>
          <summary class="editorial-faq__question">
            <span>{{ block.settings.question }}</span>
            <span class="editorial-faq__arrow">▾</span>
          </summary>
          <div class="editorial-faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

<style>
/* GRID */
.editorial-faq {
  padding: 100px 0;
}

.editorial-faq__grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 60px;
}

/* LEFT */
.editorial-faq__heading {
  font-size: 26px;
  font-weight: 500;
  line-height: 1.2;
}

/* RIGHT */
.editorial-faq__item {
  border-bottom: 1px solid rgb(var(--color-border-rgb) / 0.25);
}

.editorial-faq__question {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 0;
  cursor: pointer;
  font-size: 15px;
  font-weight: 600;
}

.editorial-faq__question::-webkit-details-marker {
  display: none;
}

/* ARROW */
.editorial-faq__arrow {
  font-size: 14px;
  transition: transform 0.3s ease;
}

details[open] .editorial-faq__arrow {
  transform: rotate(180deg);
}

/* ANSWER */
.editorial-faq__answer {
  padding: 0 0 22px;
  max-width: 640px;
  font-size: 14px;
  line-height: 1.7;
  opacity: 0.85;
}

/* ONE OPEN AT A TIME */
.editorial-faq__item + .editorial-faq__item {
  margin-top: 4px;
}

/* MOBILE */
@media (max-width: 900px) {
  .editorial-faq__grid {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .editorial-faq {
    padding: 60px 0;
  }

  .editorial-faq__heading {
    font-size: 22px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const items = document.querySelectorAll('.editorial-faq details');

  items.forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        items.forEach(other => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Premium FAQ (Editorial)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Left heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does delivery take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Delivery typically takes 2–3 business days across Lebanon.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium FAQ (Editorial)",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
