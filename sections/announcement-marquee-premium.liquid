{% if section.blocks.size > 0 %}
<div class="announcement-marquee color-{{ section.settings.color_scheme }}">
  <div class="announcement-marquee__track">
    <div class="announcement-marquee__content">
      {% for block in section.blocks %}
        <div class="announcement-marquee__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">
              {{ block.settings.text }}
            </a>
          {% else %}
            <span>{{ block.settings.text }}</span>
          {% endif %}
        </div>
      {% endfor %}

      {%- comment -%}
        Duplicate for seamless loop
      {%- endcomment -%}
      {% for block in section.blocks %}
        <div class="announcement-marquee__item">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">
              {{ block.settings.text }}
            </a>
          {% else %}
            <span>{{ block.settings.text }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<style>
.announcement-marquee {
  overflow: hidden;
  width: 100%;
  border-bottom: 1px solid rgb(var(--color-border-rgb) / 0.15);
  background: rgb(var(--color-background-rgb));
  color: rgb(var(--color-foreground-rgb));
}

.announcement-marquee__track {
  display: flex;
  width: 100%;
}

.announcement-marquee__content {
  display: flex;
  width: max-content;
  animation: marquee-scroll {{ section.settings.speed }}s linear infinite;
}

.announcement-marquee:hover .announcement-marquee__content {
  animation-play-state: paused;
}

.announcement-marquee__item {
  padding: 10px 28px;
  white-space: nowrap;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  opacity: 0.9;
}

.announcement-marquee__item a {
  color: inherit;
  text-decoration: none;
}

.announcement-marquee__item a:hover {
  text-decoration: underline;
  text-underline-offset: 4px;
}

@keyframes marquee-scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

@media (max-width: 749px) {
  .announcement-marquee__item {
    font-size: 12px;
    padding: 8px 20px;
  }
}
</style>

{% schema %}
{
  "name": "Moving announcement bar",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "s",
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over $75"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Moving announcement bar",
      "blocks": [
        { "type": "announcement" },
        { "type": "announcement" }
      ]
    }
  ]
}
{% endschema %}
