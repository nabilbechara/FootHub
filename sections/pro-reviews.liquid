{% comment %}
  Pro Reviews – Premium Social Proof with Stars & Verified Badges
{% endcomment %}

{%- assign avg_rating = section.settings.average_rating | default: "4.9" -%}
{%- assign total_reviews = section.settings.review_count | default: 200 -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ avg_rating | json }},
    "reviewCount": {{ total_reviews }},
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>

<section class="pro-reviews">
  <div class="pro-reviews__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-reviews__header">
        <h2>{{ section.settings.heading }}</h2>
        <div class="pro-reviews__aggregate">
          <span class="pro-reviews__aggregate-stars" aria-hidden="true">★★★★★</span>
          <span class="pro-reviews__aggregate-text">{{ avg_rating }} / 5 &middot; {{ total_reviews }}+ verified reviews</span>
        </div>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="pro-reviews__grid">
      {% for block in section.blocks %}
        {%- assign card_rating = block.settings.star_rating | default: 5 -%}
        <div class="pro-reviews__card" {{ block.shopify_attributes }}>

          <div class="pro-reviews__card-top">
            <div class="pro-reviews__stars" aria-label="{{ card_rating }} out of 5 stars">
              {% for i in (1..5) %}
                <span class="pro-reviews__star{% if i <= card_rating %} pro-reviews__star--filled{% endif %}" aria-hidden="true">★</span>
              {% endfor %}
            </div>
            <span class="pro-reviews__verified">&#10003; Verified Buyer</span>
          </div>

          <p class="pro-reviews__quote">&ldquo;{{ block.settings.review }}&rdquo;</p>

          <div class="pro-reviews__footer">
            <span class="pro-reviews__name">{{ block.settings.name }}</span>
            {% if block.settings.meta != blank %}
              <span class="pro-reviews__meta">{{ block.settings.meta }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .pro-reviews {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: {{ section.settings.background }};
  }

  .pro-reviews__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .pro-reviews__header {
    text-align: left;
    max-width: 720px;
    margin-bottom: 40px;
  }

  .pro-reviews__header::after {
    content: "";
    display: block;
    width: 48px;
    height: 2px;
    background: #111;
    margin-top: 16px;
  }

  .pro-reviews__header h2 {
    margin: 0 0 6px;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: #111;
  }

  .pro-reviews__header p {
    margin: 10px 0 0;
    font-size: 1rem;
    color: #6b7280;
  }

  .pro-reviews__aggregate {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
  }

  .pro-reviews__aggregate-stars {
    color: #f59e0b;
    font-size: 1.1rem;
    letter-spacing: 1px;
  }

  .pro-reviews__aggregate-text {
    font-size: 0.88rem;
    color: #374151;
    font-weight: 500;
  }

  /* GRID */
  .pro-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* CARD */
  .pro-reviews__card {
    background: #ffffff;
    border-radius: {{ section.settings.radius }}px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
  }

  .pro-reviews__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pro-reviews__stars {
    display: flex;
    gap: 1px;
  }

  .pro-reviews__star {
    font-size: 1rem;
    color: #d1d5db;
  }

  .pro-reviews__star--filled {
    color: #f59e0b;
  }

  .pro-reviews__verified {
    font-size: 0.7rem;
    font-weight: 600;
    color: #059669;
    background: #d1fae5;
    padding: 3px 9px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .pro-reviews__quote {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: #111;
    flex: 1;
  }

  .pro-reviews__footer {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pro-reviews__name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #111;
  }

  .pro-reviews__meta {
    font-size: 0.8rem;
    color: #6b7280;
  }

  /* MOBILE */
  @media (max-width: 1024px) {
    .pro-reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .pro-reviews {
      padding-right: 0;
      padding-left: 0;
    }

    .pro-reviews__inner {
      max-width: none;
    }

    .pro-reviews__header {
      margin-right: 24px;
      margin-left: 24px;
      margin-bottom: 30px;
    }

    .pro-reviews__aggregate {
      flex-wrap: wrap;
      row-gap: 4px;
    }

    .pro-reviews__grid {
      display: flex;
      gap: 16px;
      overflow-x: auto;
      padding: 0 24px 8px;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 24px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .pro-reviews__grid::-webkit-scrollbar {
      display: none;
    }

    .pro-reviews__card {
      flex: 0 0 min(86vw, 420px);
      min-height: 300px;
      padding: 24px;
      scroll-snap-align: start;
    }

    .pro-reviews__quote {
      font-size: 0.98rem;
      line-height: 1.62;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by players"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real feedback from footballers who care about performance."
    },
    {
      "type": "text",
      "id": "average_rating",
      "label": "Average rating (e.g. 4.9)",
      "default": "4.9"
    },
    {
      "type": "range",
      "id": "review_count",
      "label": "Total review count (for display)",
      "min": 0,
      "max": 9900,
      "step": 100,
      "default": 200
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "radius",
