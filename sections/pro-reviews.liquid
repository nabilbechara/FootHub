{% comment %}
  Pro Reviews – Premium Social Proof (Mock Data)
{% endcomment %}

<section class="pro-reviews">
  <div class="pro-reviews__inner">

    {% if section.settings.heading != blank %}
      <header class="pro-reviews__header">
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="pro-reviews__grid">
      {% for block in section.blocks %}
        <div class="pro-reviews__card" {{ block.shopify_attributes }}>
          <p class="pro-reviews__quote">“{{ block.settings.review }}”</p>

          <div class="pro-reviews__footer">
            <span class="pro-reviews__name">{{ block.settings.name }}</span>
            {% if block.settings.meta != blank %}
              <span class="pro-reviews__meta">{{ block.settings.meta }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .pro-reviews {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: {{ section.settings.background }};
  }

  .pro-reviews__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .pro-reviews__header {
  text-align: left;
  max-width: 720px;
  margin-bottom: 40px;
}

.pro-reviews__header::after {
  content: "";
  display: block;
  width: 48px;
  height: 2px;
  background: #111;
  margin-top: 16px;
}


  .pro-reviews__header h2 {
    margin: 0 0 8px;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: #111;
  }

  .pro-reviews__header p {
    margin: 0;
    font-size: 1rem;
    color: #6b7280;
  }

  /* GRID */
  .pro-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* CARD */
  .pro-reviews__card {
    background: #ffffff;
    border-radius: {{ section.settings.radius }}px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
  }

  .pro-reviews__quote {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #111;
  }

  .pro-reviews__footer {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
  }

  .pro-reviews__name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #111;
  }

  .pro-reviews__meta {
    font-size: 0.8rem;
    color: #6b7280;
  }

  /* MOBILE */
  @media (max-width: 900px) {
    .pro-reviews__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Pro Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by players"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real feedback from footballers who care about performance."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#f9fafb"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "The boots arrived fast and the quality exceeded my expectations. Comfort and grip are on another level."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Alex M."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (optional)",
          "default": "Semi-pro midfielder"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Pro Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review": "The boots arrived fast and the quality exceeded my expectations. Comfort and grip are on another level.",
            "name": "Alex M.",
            "meta": "Semi-pro midfielder"
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "I’ve tried a lot of kits over the years, but the fit and fabric here feel match-ready straight out of the box.",
            "name": "Daniel R.",
            "meta": "Sunday league captain"
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "Everything from packaging to performance feels professional. You can tell this store understands football.",
            "name": "Chris L.",
            "meta": "Youth academy coach"
          }
        }
      ]
    }
  ]
}
{% endschema %}
